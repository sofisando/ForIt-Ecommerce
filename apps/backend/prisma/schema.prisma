// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CLIENT
}
model User{
  id   String @id @default(uuid())
  name String
  DNI String
  email String @unique
  password String
  role UserRole
}

model Category{
  id   String @id @default(uuid())
  name String
  products Product[]
  discounts Discount[] @relation("DiscountCategories")
}

model Product{
  id   String @id @default(uuid())
  name String
  description String
  imageUrl String
  price Decimal
  categoryId String
  category Category @relation(fields: [categoryId], references: [id])
  variants Variant[]
  discounts Discount[] @relation("DiscountProducts")
}

model Variant {
  id        String  @id @default(uuid())
  title      String // COLOR, SIZE, MATERIAL
  name      String      // rojo, s, cuero
  value     String?     // hex, url, null
  productId String
  product   Product @relation(fields: [productId], references: [id])
  @@index([title, name])
  @@index([productId])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Discount{
  id     String  @id @default(uuid())
  name String
  type DiscountType
  value Int
  active Boolean
  dateFrom DateTime
  dateTo DateTime

  products   Product[]   @relation("DiscountProducts")
  categories Category[]  @relation("DiscountCategories")
}

// ponemos los datos que se guardan, como esten o como se representen seria el DTO
enum OrderState {
  PENDING
  ACEPTED
  READY
  CANCELED
  DELIVERED
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  branchId  String?
  total     Decimal
  state     OrderState
  date      DateTime    @default(now())

  items     OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId  String
  order    Order    @relation(fields: [orderId], references: [id])

  productId String
  name      String
  price     Decimal
  quantity  Int
  subtotal  Decimal

  // snapshots embebidos
  variant   Json?
  discount  Json?
}