generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CLIENT
}
model User{
  id   String @id @default(uuid())
  name String
  DNI String
  email String @unique
  password String //en realidad hay que guardar el hash
  role UserRole
}

model Category{
  id   String @id @default(uuid())
  name String
  products Product[]
}

model Product{
  id   String @id @default(uuid())
  name String
  description String
  imageUrl String
  price Int
  categoryId String
  category Category @relation(fields: [categoryId], references: [id])
}